# ============================================================================
# Cursor Instance - Copy this to .env.cursor (or .env if running single IDE)
# ============================================================================
# Launch Cursor with: Cursor.exe --remote-debugging-port=9222
# Or use: launch-cursor-debug.bat (in project root)
#
# Run with: DOTENV_CONFIG_PATH=.env.cursor npx tsx src/index.ts
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info
PORT=8787

# --- IDE Target ---
BRIDGE_IDE_TARGET=cursor
BRIDGE_BACKEND_MODE=cdp
BRIDGE_API_AUTH_TOKEN=

# --- Telegram Bot ---
# Create via @BotFather: https://t.me/BotFather → /newbot → name it "Cursor Bridge" or similar
# IMPORTANT: Use a dedicated bot token per IDE instance.
TELEGRAM_BOT_TOKEN=
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_REQUEST_TIMEOUT_MS=30000

# --- Cursor CDP ---
CURSOR_REMOTE_DEBUG_URL=http://127.0.0.1:9222
CURSOR_APP_EXE=Cursor
CURSOR_TARGET_TITLE_HINT=Cursor
CURSOR_CHAT_INPUT_SELECTOR=
CURSOR_RESPONSE_SELECTOR=
CURSOR_CONTEXT_SELECTOR=
CURSOR_MODEL_SELECTOR=
CURSOR_CONTEXT_REGION=
CURSOR_CONTEXT_HOVER_POINT=
CURSOR_ACTION_TIMEOUT_MS=30000
# Leave blank for auto-detect, or set to your local state.vscdb path.(\AppData\Roaming\cursor\User\globalStorage\state.vscdb)
CURSOR_SQLITE_PATH=

# --- Cursor API (optional, only if BRIDGE_BACKEND_MODE=api) ---
CURSOR_API_KEY=
CURSOR_API_BASE_URL=https://api.cursor.com
CURSOR_API_REPOSITORY=
CURSOR_API_MODEL=
CURSOR_API_REF=
CURSOR_API_TIMEOUT_MS=30000

# --- Discord (optional) ---
# Create bot: https://discord.com/developers/applications → New App → Bot → Copy token
# IMPORTANT: Use a dedicated bot token per IDE instance.
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=

# --- Email (optional) ---
EMAIL_ENABLED=false
EMAIL_ALLOWED_FROM=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_POLL_INTERVAL_MS=30000

# --- Feishu (optional) ---
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_ALLOWED_OPEN_IDS=
