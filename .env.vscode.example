# ============================================================================
# VS Code Instance - Copy this to .env.vscode (or .env if running single IDE)
# ============================================================================
# Launch VS Code with: Code.exe --remote-debugging-port=9224
# Or use: launch-vscode-debug.bat (in project root)
#
# Run with: DOTENV_CONFIG_PATH=.env.vscode npx tsx src/index.ts
# ============================================================================

NODE_ENV=development
LOG_LEVEL=info
PORT=8789

# --- IDE Target ---
BRIDGE_IDE_TARGET=vscode
BRIDGE_BACKEND_MODE=cdp
BRIDGE_API_AUTH_TOKEN=

# --- Telegram Bot ---
# Create via @BotFather: https://t.me/BotFather → /newbot → name it "VS Code Bridge" or similar
# IMPORTANT: Use a dedicated bot token per IDE instance.
TELEGRAM_BOT_TOKEN=
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_REQUEST_TIMEOUT_MS=30000

# --- VS Code CDP ---
VSCODE_REMOTE_DEBUG_URL=http://127.0.0.1:9224
VSCODE_TARGET_TITLE_HINT=Code
VSCODE_CHAT_INPUT_SELECTOR=textarea,[contenteditable="true"],[role="textbox"]
VSCODE_RESPONSE_SELECTOR=[class*="markdown"],[role="article"],article
VSCODE_MODE_SELECTOR=
VSCODE_CONTEXT_SELECTOR=
VSCODE_MODEL_SELECTOR=
VSCODE_ACTION_TIMEOUT_MS=30000
# Leave blank for auto-detect, or set to your local state.vscdb path.(\AppData\Roaming\Code\User\globalStorage\state.vscdb)
VSCODE_SQLITE_PATH=

# --- Discord (optional) ---
# Create bot: https://discord.com/developers/applications → New App → Bot → Copy token
# IMPORTANT: Use a dedicated bot token per IDE instance.
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=

# --- Email (optional) ---
EMAIL_ENABLED=false
EMAIL_ALLOWED_FROM=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_USER=
EMAIL_IMAP_PASS=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_POLL_INTERVAL_MS=30000

# --- Feishu (optional) ---
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_ALLOWED_OPEN_IDS=
